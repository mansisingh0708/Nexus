<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:padding="24dp">

    <!-- 1. The Home Dashboard layer (Visible ONLY in Screen.HOME) -->
    <RelativeLayout
        android:id="@+id/homeDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Profile Section -->
        <LinearLayout
            android:id="@+id/topProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_alignParentTop="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good Morning,"
                    android:textColor="@color/text_med"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sarah"
                    android:textColor="@color/text_high"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/glass_background"
                android:src="@drawable/ic_home"
                android:padding="12dp"
                app:tint="@color/text_med"/>
        </LinearLayout>

        <!-- Balance Card -->
        <LinearLayout
            android:id="@+id/balanceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_background"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginTop="24dp"
            android:layout_below="@id/topProfile">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Balance:"
                    android:textColor="@color/text_med"/>
                <TextView
                    android:id="@+id/visaText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VISA"
                    android:layout_alignParentEnd="true"
                    android:textStyle="bold"
                    android:textColor="@color/text_high"
                    android:textSize="18sp"/>
            </RelativeLayout>

            <TextView
                android:id="@+id/balanceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$4,350.20"
                android:textColor="@color/text_high"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="**** **** **** 0010"
                android:textColor="@color/text_med"
                android:textSize="18sp"
                android:layout_marginTop="16dp"
                android:letterSpacing="0.2"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cardholder name"
                    android:textColor="@color/text_med"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZARIYA"
                    android:layout_alignParentEnd="true"
                    android:textColor="@color/text_high"/>
            </RelativeLayout>
        </LinearLayout>

        <!-- SEND and REQUEST buttons at bottom -->
        <LinearLayout
            android:id="@+id/actionButtons"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:layout_alignParentBottom="true">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="SEND"
                android:textColor="@color/text_high"
                android:textStyle="bold"
                android:textSize="16sp"
                android:gravity="center"
                android:background="@drawable/neon_button_bg"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="REQUEST"
                android:textColor="@color/text_high"
                android:textSize="16sp"
                android:gravity="center"
                android:background="@drawable/outline_button_bg"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        
        <!-- Helpful text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/actionButtons"
            android:layout_marginBottom="32dp"
            android:text="Swipe Right: Scan QR | Swipe Left: Balance"
            android:textColor="@color/text_med"
            android:gravity="center"
            android:textSize="14sp"/>

    </RelativeLayout>

    <!-- 2. Drawing Prompt Layer (Visible ONLY in Screen.AMOUNT and Screen.PIN) -->
    <RelativeLayout
        android:id="@+id/drawingPromptLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark"
        android:visibility="gone">
        
        <TextView
            android:id="@+id/promptText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="DRAW AMOUNT"
            android:textColor="@color/accent"
            android:textSize="40sp"
            android:textStyle="bold"
            android:shadowColor="@color/primary"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="30"
            android:letterSpacing="0.1"/>
    </RelativeLayout>

    <!-- 3. Success Layer -->
    <LinearLayout
        android:id="@+id/successCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0A0014"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <!-- Outer Glowing Box bounding the success info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/neon_success_bg"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp">

        <!-- Glowing Circle with Tick -->
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/neon_glow_circle"
                android:layout_centerInParent="true"/>

            <ImageView
                android:id="@+id/successTick"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_check"
                app:tint="@color/neon_green"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/successText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAYMENT SECURED"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_high"
            android:shadowColor="@color/neon_green"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="25"
            android:letterSpacing="0.1"
            android:layout_marginTop="32dp"
            android:gravity="center"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transaction encrypted and finalized"
            android:textSize="14sp"
            android:textColor="@color/neon_green"
            android:layout_marginTop="8dp"
            android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 4. The Drawing Container (Absolute Root level, always matches parent) -->
    <!-- It acts as a transparent overlay that covers the entire screen -->
    <FrameLayout
        android:id="@+id/drawContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</RelativeLayout>